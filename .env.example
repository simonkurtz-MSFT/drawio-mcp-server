# Container Registry Configuration
# Set REGISTRY to your Azure Container Registry (e.g., myregistry.azurecr.io)
# or Docker Hub (e.g., docker.io/myusername)
REGISTRY=myregistry.azurecr.io

# Push image to registry during build
# Set to 'true' to push after building, 'false' or omit to skip pushing
PUSH_IMAGE=false

# Image version for docker tags (semver format: major.minor.patch)
IMAGE_VERSION=1.0.0
